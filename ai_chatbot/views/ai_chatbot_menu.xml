<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ─── Client Action: Open chat widget ──────────────────────────────── -->
  <record id="action_ai_chatbot_open" model="ir.actions.client">
    <field name="name">AI Analytics Chatbot</field>
    <field name="tag">ai_chatbot.action</field>
  </record>

  <!-- ─── Top-level Menu ────────────────────────────────────────────────── -->
  <menuitem id="menu_ai_chatbot_root"
            name="AI Chatbot"
            sequence="99"
            web_icon="ai_chatbot,static/src/img/icon.png"/>

  <!-- Main chat UI -->
  <menuitem id="menu_ai_chatbot_main"
            name="AI Analytics"
            parent="menu_ai_chatbot_root"
            action="action_ai_chatbot_open"
            sequence="1"/>

  <!-- Admin: conversation log -->
  <menuitem id="menu_ai_chatbot_log"
            name="Conversation History"
            parent="menu_ai_chatbot_root"
            action="action_ai_chatbot_conversation_log"
            sequence="2"
            groups="base.group_system"/>

</odoo>
